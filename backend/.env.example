# Copy this to .env and fill values locally. DO NOT commit real secrets.
PORT=8000
# For MongoDB Atlas use a connection string without the DB name, e.g.
# mongodb+srv://<user>:<password>@cluster0.abcd123.mongodb.net
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net
# Alternatively Railway/Postgres add-ons often expose DATABASE_URL
# The app will prefer DATABASE_URL over MONGODB_URI when present
DATABASE_URL=
FRONTEND_URL=http://localhost:8081
ACCESS_TOKEN_SECRET=replace_me
ACCESS_TOKEN_EXPIRY=7d
REFRESH_TOKEN_SECRET=replace_me
REFRESH_TOKEN_EXPIRY=30d
